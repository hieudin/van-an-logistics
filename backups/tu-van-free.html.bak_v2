  <script>


    // ── TELEGRAM CONFIG ──
    const TG_TOKEN = '8756025848:AAHyyvQHdYaEy15_qQh_MPyHS6Si5gDpklU';
    const TG_CHAT = '952234412';

    function sendTelegram(text) {
      fetch('https://api.telegram.org/bot' + TG_TOKEN + '/sendMessage', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: TG_CHAT, text: text, parse_mode: 'HTML' })
      }).catch(() => { });
    }

    // ── FORM SUBMIT ──
    function submitForm() {
      const name = document.getElementById('fullName').value.trim();
      const phone = document.getElementById('phone').value.trim();

      if (!name) {
        alert('Vui lòng nhập họ và tên của bạn.');
        document.getElementById('fullName').focus();
        return;
      }
      if (!phone || !/^[0-9+\s\-]{9,15}$/.test(phone)) {
        alert('Vui lòng nhập số điện thoại hợp lệ.');
        document.getElementById('phone').focus();
        return;
      }

      const service = document.getElementById('service').value;
      const cargo = document.getElementById('cargo').value.trim();

      const serviceMap = {
        'hang-le': 'Vận chuyển hàng lẻ',
        'nguyen-cont': 'Nguyên container',
        'uy-thac': 'Ủy thác nhập khẩu',
        'thanh-toan': 'Thanh toán hộ (Alipay)',
        'order': 'Order hàng Taobao/1688',
        'khac': 'Khác'
      };

      const now = new Date().toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' });
      const msg =
        '📋 <b>LEAD MỚI — LANDING FB</b>\n' +
        '─────────────────────\n' +
        '👤 <b>Họ tên:</b> ' + name + '\n' +
        '📞 <b>SĐT/Zalo:</b> ' + phone + '\n' +
        '📦 <b>Dịch vụ:</b> ' + (serviceMap[service] || 'Chưa chọn') + '\n' +
        '📝 <b>Hàng hóa:</b> ' + (cargo || 'Chưa nhập') + '\n' +
        '─────────────────────\n' +
        '🌐 <b>Nguồn:</b> ' + (document.referrer || 'Facebook Ads') + '\n' +
        '🕐 <b>Thời gian:</b> ' + now + '\n' +
        '⚡ <i>Phản hồi trong 15 phút!</i>';

      sendTelegram(msg);

      // Show success UI
      document.getElementById('customerName').textContent = name;
      document.getElementById('leadForm').style.display = 'none';
      document.getElementById('successState').style.display = 'block';

      // Scroll to confirmation
      document.querySelector('.form-card').scrollIntoView({ behavior: 'smooth', block: 'center' });

      // Track Facebook Pixel Lead event if available
      if (typeof fbq === 'function') {
        fbq('track', 'Lead', { content_name: 'Van An Logistics Form', value: service });
      }
    }

    // ── SCROLL REVEAL ──
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));

    // ── FORM ENTER KEY ──
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA') submitForm();
    });
  </script>

